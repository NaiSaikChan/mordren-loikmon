{
  "name": "@loikmon/api",
  "version": "1.0.0",
  "description": "Shared TypeScript API client for Loikmon",
  "main": "./src/index.ts",
  "module": "dist/index.js",
  "types": "./src/index.ts",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "axios": "^1.7.2"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.1.9",
    "typescript": "^5.4.5",
    "vitest": "^2.1.9"
  },
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "require": "./src/index.ts",
      "types": "./src/index.ts"
    }
  }
}